  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "NeteaseCloudMusicApi": "^4.32.0",
    "postcss": "^8.5.1",
